generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum Role {
  BOSS
  ADMIN
  VIEWER
}

enum NewsStatus {
  DRAFT
  PUBLISHED
  DELETED
}

// ─── Models ──────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(uuid())
  username  String   @unique
  email     String   @unique
  password  String
  role      Role     @default(ADMIN)
  name      String
  surname   String
  isBlocked Boolean  @default(false)
  createdAt DateTime @default(now())

  news         News[]
  comments     Comment[]
  likes        Like[]
  refreshTokens RefreshToken[]

  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([token])
  @@index([userId])
  @@map("refresh_tokens")
}

model Category {
  id        String  @id @default(uuid())
  name      String
  slug      String  @unique
  isDeleted Boolean @default(false)

  news News[]

  @@map("categories")
}

model News {
  id               String     @id @default(uuid())
  title            String
  slug             String     @unique
  content          String
  shortDescription String
  categoryId       String
  authorId         String
  status           NewsStatus @default(DRAFT)
  viewCount        Int        @default(0)
  rank             Int        @default(0)
  createdAt        DateTime   @default(now())
  updatedAt        DateTime   @updatedAt

  category Category     @relation(fields: [categoryId], references: [id])
  author   User         @relation(fields: [authorId], references: [id])
  comments Comment[]
  likes    Like[]
  views    View[]
  images   Image[]
  hashtags HashtagNews[]

  @@index([slug])
  @@index([createdAt])
  @@index([categoryId])
  @@index([status])
  @@index([authorId])
  @@map("news")
}

model Comment {
  id        String   @id @default(uuid())
  newsId    String
  userId    String
  content   String
  username  String
  createdAt DateTime @default(now())
  isDeleted Boolean  @default(false)

  news News @relation(fields: [newsId], references: [id])
  user User @relation(fields: [userId], references: [id])

  @@index([newsId])
  @@index([userId])
  @@map("comments")
}

model Like {
  id        String   @id @default(uuid())
  userId    String?
  newsId    String
  ipAddress String
  createdAt DateTime @default(now())

  news News  @relation(fields: [newsId], references: [id])
  user User? @relation(fields: [userId], references: [id])

  @@unique([userId, newsId, ipAddress])
  @@index([newsId])
  @@map("likes")
}

model View {
  id        String   @id @default(uuid())
  newsId    String
  ipAddress String
  createdAt DateTime @default(now())

  news News @relation(fields: [newsId], references: [id])

  @@index([newsId])
  @@index([ipAddress])
  @@map("views")
}

model Hashtag {
  id   String @id @default(uuid())
  name String
  slug String @unique

  news HashtagNews[]

  @@map("hashtags")
}

model HashtagNews {
  id        String  @id @default(uuid())
  hashtagId String
  newsId    String
  isDeleted Boolean @default(false)

  hashtag Hashtag @relation(fields: [hashtagId], references: [id])
  news    News    @relation(fields: [newsId], references: [id])

  @@unique([hashtagId, newsId])
  @@index([newsId])
  @@index([hashtagId])
  @@map("hashtag_news")
}

model Image {
  id        String  @id @default(uuid())
  newsId    String
  url       String
  isDeleted Boolean @default(false)

  news News @relation(fields: [newsId], references: [id])

  @@index([newsId])
  @@map("images")
}
